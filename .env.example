# Alpaca Markets (Paper Trading)
ALPACA_API_KEY=your_alpaca_key_id_here
ALPACA_SECRET_KEY=your_alpaca_secret_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets
LIVE_TRADING=false

# NewsAPI (newsapi.org)
NEWS_API_KEY=your_newsapi_key_here

# Discord
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# Anthropic (optional) — enables LLM news sentiment + trade narration.
# Without it the system falls back to VADER sentiment and templated summaries.
ANTHROPIC_API_KEY=your_anthropic_key_here
# Optional: override the model (default claude-opus-4-8; claude-haiku-4-5 is
# the cheaper choice for this daily classification workload).
# LLM_MODEL=claude-opus-4-8

# Neon.tech PostgreSQL
# Format: postgresql://user:password@host/dbname?sslmode=require
DB_URL=your_neon_connection_string_here
